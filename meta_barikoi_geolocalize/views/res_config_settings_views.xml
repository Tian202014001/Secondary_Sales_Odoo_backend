<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Extend Barikoi Settings with Geolocalize Options -->
        <record id="res_config_settings_view_form_inherit_barikoi_geolocalize" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.barikoi.geolocalize</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="meta_barikoi_base.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@id='barikoi_settings_content']" position="inside">
                    <div class="mt8">
                        <field name="barikoi_auto_geocode_partners"/>
                        <label for="barikoi_auto_geocode_partners" string="Auto Geocode Partners"/>
                    </div>
                    <div class="mt8">
                        <label for="barikoi_nearby_distance_threshold" string="Nearby Distance (km)" class="col-3 col-lg-3 o_light_label"/>
                        <field name="barikoi_nearby_distance_threshold" class="oe_inline"/>
                    </div>
                </xpath>
            </field>
        </record>
    </data>
</odoo>