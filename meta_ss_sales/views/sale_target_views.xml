<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_sale_target_form" model="ir.ui.view">
        <field name="name">sale.target.form</field>
        <field name="model">sale.target</field>
        <field name="arch" type="xml">
            <form string="Sale Target">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="month"/>
                            <field name="year"/>
                        </group>
                        <group>
                            <field name="date_from" readonly="1" force_save="1"/>
                            <field name="date_to" readonly="1" force_save="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Target Lines" name="target_lines">
                            <field name="target_line_ids">
                                <list editable="bottom">
                                    <field name="employee_id"/>
                                    <field name="product_id"/>
                                    <field name="product_uom"/>
                                    <field name="target_qty"/>
                                    <field name="daily_target_qty" readonly="1" force_save="1"/>
                                    <field name="achieved_target_qty" readonly="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_sale_target_tree" model="ir.ui.view">
        <field name="name">sale.target.tree</field>
        <field name="model">sale.target</field>
        <field name="arch" type="xml">
            <list string="Sale Targets">
                <field name="name"/>
                <field name="month"/>
                <field name="year"/>
                <field name="date_from"/>
                <field name="date_to"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="action_sale_target" model="ir.actions.act_window">
        <field name="name">Sale Targets</field>
        <field name="res_model">sale.target</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Sale Target
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_sale_target"
              name="Sale Targets"
              parent="sale.sale_order_menu"
              action="action_sale_target"
              sequence="50"/>
</odoo>
