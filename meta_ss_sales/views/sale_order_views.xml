<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_order_form_inherit_meta_ss_sales" model="ir.ui.view">
           <field name="name">sale.order.form.inherit.meta.ss.sales</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='payment_term_id']" position="after">
                    <field name="sale_type"/>
                    <field name="so_employee_id"/>
                    <field name="route_id" domain="[('active', '=', True), '|', ('ss_employee_id', '=', False), ('ss_employee_id', '=', so_employee_id)]" invisible="sale_type != 'secondary'"/>
                    <field name="visit_id" domain="[('outlet_id', '=', partner_id)]" invisible="sale_type != 'secondary'"/>
                </xpath>
                <xpath expr="//field[@name='order_line']/list/field[@name='product_uom_qty']" position="after">
                    <field name="damaged_qty" column_invisible="parent.sale_type != 'secondary'"/>
                </xpath>
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_view_damaged_receipt"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-exchange"
                            invisible="sale_type != 'secondary' or damaged_picking_count == 0">
                        <field name="damaged_picking_count" widget="statinfo" string="Damaged Returns"/>
                    </button>
                </xpath>
                <!-- Restrict Confirm buttons to Finance Team group -->
                <xpath expr="//button[@name='action_confirm'][@id='action_confirm']" position="attributes">
                    <attribute name="groups">meta_ss_sales.group_ss_finance_team</attribute>
                </xpath>
                <xpath expr="//button[@name='action_confirm'][not(@id)]" position="attributes">
                    <attribute name="groups">meta_ss_sales.group_ss_finance_team</attribute>
                </xpath>

                <!-- Restrict Create Invoice buttons to Supply Chain Coordinator group -->
                <xpath expr="//button[@name='%(sale.action_view_sale_advance_payment_inv)d'][1]" position="attributes">
                    <attribute name="groups">meta_ss_sales.group_ss_supply_chain_coordinator</attribute>
                </xpath>
                <xpath expr="//button[@name='%(sale.action_view_sale_advance_payment_inv)d'][2]" position="attributes">
                    <attribute name="groups">meta_ss_sales.group_ss_supply_chain_coordinator</attribute>
                </xpath>
            </field>
        </record>

        <!-- Primary Sales Action -->
        <record id="action_primary_sales_order" model="ir.actions.act_window">
            <field name="name">Primary Sales</field>
            <field name="res_model">sale.order</field>
            <field name="view_mode">list,form,kanban,calendar,pivot,graph,activity</field>
            <field name="domain">[('sale_type', '=', 'primary')]</field>
            <field name="context">{'default_sale_type': 'primary'}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new Primary Sales Order
                </p>
            </field>
        </record>

        <!-- Secondary Sales Action -->
        <record id="action_secondary_sales_order" model="ir.actions.act_window">
            <field name="name">Secondary Sales</field>
            <field name="res_model">sale.order</field>
            <field name="view_mode">list,form,kanban,calendar,pivot,graph,activity</field>
            <field name="domain">[('sale_type', '=', 'secondary')]</field>
            <field name="context">{'default_sale_type': 'secondary'}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new Secondary Sales Order
                </p>
            </field>
        </record>

        <!-- Menus -->
        <menuitem id="menu_primary_sales_orders"
                  name="Primary Sales"
                  parent="sale.sale_order_menu"
                  action="action_primary_sales_order"
                  sequence="15"/>

        <menuitem id="menu_secondary_sales_orders"
                  name="Secondary Sales"
                  parent="sale.sale_order_menu"
                  action="action_secondary_sales_order"
                  sequence="16"/>

        <!-- Restrict stock.picking Validate buttons by Group -->
        <record id="view_picking_form_inherit_meta_ss_sales_security" model="ir.ui.view">
            <field name="name">stock.picking.form.inherit.meta.ss.sales.security</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="arch" type="xml">
                <xpath expr="//button[@name='button_validate'][@class='oe_highlight']" position="attributes">
                    <attribute name="groups">meta_ss_sales.group_ss_supply_chain_coordinator</attribute>
                </xpath>
                <xpath expr="//button[@name='button_validate'][not(contains(@class, 'oe_highlight'))]" position="attributes">
                    <attribute name="groups">meta_ss_sales.group_ss_supply_chain_coordinator</attribute>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
