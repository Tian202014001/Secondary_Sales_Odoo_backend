<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_meta_ss_location_tracking" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.meta.ss.location.tracking</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Location Tracking" name="meta_ss_location_tracking" groups="base.group_system">
                    <block title="Map Configurations">
                        <setting id="meta_ss_location_map_tile">
                            <label for="map_tile_url"/>
                            <div class="text-muted">
                                The URL template for Leaflet/OSM map background tiles (e.g. https://tile.openstreetmap.org/{z}/{x}/{y}.png).
                            </div>
                            <field name="map_tile_url"/>
                        </setting>
                    </block>
                    <block title="Location Tracking Configurations">
                        <setting id="meta_ss_location_tracking_type">
                            <label for="location_tracking_type"/>
                            <div class="text-muted">
                                Select the method for logging and syncing GPS coordinates (Time-based, Distance-based, or Both).
                            </div>
                            <field name="location_tracking_type"/>
                        </setting>
                        <setting id="meta_ss_location_tracking_interval" invisible="location_tracking_type == 'distance'">
                            <label for="location_tracking_interval"/>
                            <div class="text-muted">
                                Define the frequency (in seconds) at which mobile apps log and sync user GPS coordinates.
                            </div>
                            <field name="location_tracking_interval"/>
                        </setting>
                        <setting id="meta_ss_location_tracking_distance" invisible="location_tracking_type == 'time'">
                            <label for="location_tracking_distance"/>
                            <div class="text-muted">
                                Define the minimum distance change (in meters) to log and sync user GPS coordinates.
                            </div>
                            <field name="location_tracking_distance"/>
                        </setting>
                        <setting id="meta_ss_location_tracking_sync_interval">
                            <label for="location_tracking_sync_interval"/>
                            <div class="text-muted">
                                How often (in seconds) the mobile client uploads its buffered GPS coordinates to the server (e.g. 3600 for hourly). Sampling still follows the interval/distance above; this only controls the batch upload cadence.
                            </div>
                            <field name="location_tracking_sync_interval"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
