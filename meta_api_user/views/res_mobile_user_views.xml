<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_res_mobile_user_search" model="ir.ui.view">
        <field name="name">res.mobile.user.search</field>
        <field name="model">res.mobile.user</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="group_id"/>
                <field name="employee_id"/>
                <field name="company_id"/>
                <filter name="active" string="Active" domain="[('active', '=', True)]"/>
                <filter name="archived" string="Archived" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_mobile_group" string="Mobile Group" context="{'group_by': 'group_id'}"/>
                    <filter name="group_employee" string="Employee" context="{'group_by': 'employee_id'}"/>
                    <filter name="group_company" string="Company" context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_res_mobile_user_list" model="ir.ui.view">
        <field name="name">res.mobile.user.list</field>
        <field name="model">res.mobile.user</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="employee_id"/>
                <field name="group_id"/>
                <field name="company_id"/>
                <field name="last_login"/>
                <field name="active_session_count"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_res_mobile_user_form" model="ir.ui.view">
        <field name="name">res.mobile.user.form</field>
        <field name="model">res.mobile.user</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_sessions" type="object" class="oe_stat_button" icon="fa-key">
                            <field name="session_count" widget="statinfo" string="Sessions"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Mobile User Name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Login">
                            <field name="phone"/>
                            <field name="email"/>
                            <field name="password" password="True"/>
                            <field name="password_hash" invisible="1" groups="base.group_system" readonly="1"/>
                        </group>
                        <group string="Profile">
                            <field name="group_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="employee_id"/>
                            <field name="last_login"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Sessions">
                            <field name="session_ids" readonly="1">
                                <list>
                                    <field name="create_date"/>
                                    <field name="state"/>
                                    <field name="device_id"/>
                                    <field name="device_info"/>
                                    <field name="ip_address"/>
                                    <field name="last_used_at"/>
                                    <field name="refresh_token_expiry"/>
                                    <field name="is_revoked"/>
                                    <field name="revoke_reason"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_res_mobile_user" model="ir.actions.act_window">
        <field name="name">Mobile Users</field>
        <field name="res_model">res.mobile.user</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="meta_api_user.view_res_mobile_user_search"/>
        <field name="context">{'search_default_active': 1}</field>
    </record>
</odoo>
