<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Mobile UI Resource (Screen/Action catalog) -->
    <record id="view_mobile_ui_resource_search" model="ir.ui.view">
        <field name="name">mobile.ui.resource.search</field>
        <field name="model">mobile.ui.resource</field>
        <field name="arch" type="xml">
            <search>
                <field name="key" />
                <field name="label" />
                <field name="module" />
                <filter name="screens" string="Screens" domain="[('res_type', '=', 'screen')]" />
                <filter name="actions" string="Actions" domain="[('res_type', '=', 'action')]" />
                <separator />
                <filter name="module_managed" string="Module Managed" domain="[('module_ids', '!=', False)]" />
                <filter name="archived" string="Archived" domain="[('active', '=', False)]" />
                <group expand="0" string="Group By">
                    <filter name="group_module" string="Module" context="{'group_by': 'module'}" />
                    <filter name="group_type" string="Type" context="{'group_by': 'res_type'}" />
                </group>
            </search>
        </field>
    </record>

    <record id="view_mobile_ui_resource_list" model="ir.ui.view">
        <field name="name">mobile.ui.resource.list</field>
        <field name="model">mobile.ui.resource</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="key" />
                <field name="res_type" />
                <field name="module" />
                <field name="label" />
                <field name="module_ids" widget="many2many_tags" />
                <field name="last_seen" optional="hide" readonly="1" />
                <field name="active" widget="boolean_toggle" optional="hide" />
            </list>
        </field>
    </record>

    <record id="action_mobile_ui_resource" model="ir.actions.act_window">
        <field name="name">UI Access Catalog</field>
        <field name="res_model">mobile.ui.resource</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="meta_api_user.view_mobile_ui_resource_search" />
        <field name="context">{'search_default_group_module': 1}</field>
    </record>
    <!-- Menu lives in menu_views.xml (loaded after this file) so the parent
         menu external id resolves. -->
</odoo>
