<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ss_module_search" model="ir.ui.view">
        <field name="name">ss.module.search</field>
        <field name="model">ss.module</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <filter name="archived" string="Archived" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="view_ss_module_list" model="ir.ui.view">
        <field name="name">ss.module.list</field>
        <field name="model">ss.module</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_ss_module_form" model="ir.ui.view">
        <field name="name">ss.module.form</field>
        <field name="model">ss.module</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Module Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code" placeholder="e.g. primary_sales"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Resources" name="resources">
                            <field name="resource_ids">
                                <list>
                                    <field name="key"/>
                                    <field name="res_type"/>
                                    <field name="module"/>
                                    <field name="label"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ss_module" model="ir.actions.act_window">
        <field name="name">Mobile Modules</field>
        <field name="res_model">ss.module</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_ss_module_search"/>
    </record>
</odoo>
