<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_partner_form_inherit_meta_ss_contact" model="ir.ui.view">
            <field name="name">res.partner.form.inherit.meta.ss.contact</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='category_id']" position="after">
                    <field name="customer_type"/>
                    
                    <field name="scrap_location_id"
                           invisible="customer_type != 'distributor'"/>
                </xpath>
            </field>
        </record>

        <!-- Actions -->
        <record id="action_distributors" model="ir.actions.act_window">
            <field name="name">Distributors</field>
            <field name="res_model">res.partner</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="domain">[('customer_type', '=', 'distributor')]</field>
            <field name="context">{'default_customer_type': 'distributor'}</field>
        </record>

        <record id="action_outlets" model="ir.actions.act_window">
            <field name="name">Outlets</field>
            <field name="res_model">res.partner</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="domain">[('customer_type', '=', 'outlet')]</field>
            <field name="context">{'default_customer_type': 'outlet'}</field>
        </record>

        <!-- Menus under Contacts App -> Contacts submenu -->
        <menuitem id="menu_distributors" name="Distributors" parent="contacts.res_partner_menu_contacts" action="action_distributors" sequence="10"/>
        <menuitem id="menu_outlets" name="Outlets" parent="contacts.res_partner_menu_contacts" action="action_outlets" sequence="20"/>
    </data>
</odoo>
