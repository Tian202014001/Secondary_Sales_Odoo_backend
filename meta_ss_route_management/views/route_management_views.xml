<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Tree (List) View -->
        <record id="view_sale_route_tree" model="ir.ui.view">
            <field name="name">sale.route.list</field>
            <field name="model">sale.route</field>
            <field name="arch" type="xml">
                <list string="Routes">
                    <field name="name"/>
                    <field name="code" />
                    <field name="ss_employee_id"/>
                    <field name="distributor_contact_id" />
                    <field name="active" />
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_sale_route_form" model="ir.ui.view">
            <field name="name">sale.route.form</field>
            <field name="model">sale.route</field>
            <field name="arch" type="xml">
                <form string="Route">
                    <sheet>
                        <group>
                            <group>
                                <field name="name" />
                                <field name="code" />
                                <field name="ss_employee_id"/>
                            </group>
                            <group>
                                <field name="distributor_contact_id" />
                                <field name="active" />
                            </group>
                        </group>
                        <notebook>
                            <page string="Route Outlets" name="route_outlets">
                                <field name="route_line_ids">
                                    <list editable="bottom">
                                        <field name="sequence" widget="handle" />
                                        <field name="outlet_id"
                                            domain="[('customer_type', '=', 'outlet')]" />
                                    
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Window Action -->
        <record id="action_sale_route" model="ir.actions.act_window">
            <field name="name">Routes</field>
            <field name="res_model">sale.route</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first route!
                </p>
            </field>
        </record>

        <!-- Menu Items -->
        <menuitem id="menu_sale_route_root" name="Route Management" sequence="82" web_icon="meta_ss_route_management,static/description/icon.png" />

        <menuitem id="menu_sale_route" name="Routes" parent="menu_sale_route_root"
            action="action_sale_route" sequence="10" />

    </data>
</odoo>