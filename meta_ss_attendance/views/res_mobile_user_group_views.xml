<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_res_mobile_user_group_form_inherit_attendance" model="ir.ui.view">
        <field name="name">res.mobile.user.group.form.inherit.attendance</field>
        <field name="model">res.mobile.user.group</field>
        <field name="inherit_id" ref="meta_api_user.view_res_mobile_user_group_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='configuration']" position="inside">
                <group string="Attendance &amp; Geolocation">
                    <field name="skip_attendance_geolocation" widget="boolean_toggle"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
