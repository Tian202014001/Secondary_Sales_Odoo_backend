<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_process_mobile_push_notifications" model="ir.cron">
            <field name="name">Process Mobile Push Notifications</field>
            <field name="model_id" ref="model_mobile_notification_service"/>
            <field name="state">code</field>
            <field name="code">model.process_pending_notifications()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
