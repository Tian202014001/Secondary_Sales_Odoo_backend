<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_leave_form_inherit_request_source" model="ir.ui.view">
        <field name="name">hr.leave.form.inherit.request_source</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='holiday_status_id']" position="after">
                <field name="request_source" readonly="1" groups="base.group_no_one"/>
            </xpath>
        </field>
    </record>

    <record id="view_hr_leave_tree_inherit_request_source" model="ir.ui.view">
        <field name="name">hr.leave.tree.inherit.request_source</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='holiday_status_id']" position="after">
                <field name="request_source" optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>
