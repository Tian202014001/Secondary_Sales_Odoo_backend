<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_partner_form_inherit_meta_ss_transfer" model="ir.ui.view">
            <field name="name">res.partner.form.inherit.meta_ss_transfer</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_view_van_locations"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-truck"
                            invisible="customer_type != 'distributor'">
                        <div class="o_field_widget o_stat_info">
                            <span class="o_stat_value"><field name="van_location_count"/></span>
                            <span class="o_stat_text">Van Locations</span>
                        </div>
                    </button>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
