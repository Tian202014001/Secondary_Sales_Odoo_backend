<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_location_form_inherit_meta_ss_transfer" model="ir.ui.view">
            <field name="name">stock.location.form.inherit.meta.ss.transfer</field>
            <field name="model">stock.location</field>
            <field name="inherit_id" ref="stock.view_location_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='usage']" position="after">
                    <field name="ss_location_type"/>
                    <field name="ss_distributor_id" 
                           invisible="ss_location_type != 'van_loading'" 
                           required="ss_location_type == 'van_loading'"/>
                    <field name="ss_employee_id" 
                           invisible="ss_location_type != 'van_loading'" 
                           required="ss_location_type == 'van_loading'"/>
                </xpath>
            </field>
        </record>

        <record id="view_location_tree_inherit_meta_ss_transfer" model="ir.ui.view">
            <field name="name">stock.location.list.inherit.meta.ss.transfer</field>
            <field name="model">stock.location</field>
            <field name="inherit_id" ref="stock.view_location_tree2"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='usage']" position="after">
                    <field name="ss_location_type"/>
                    <field name="ss_employee_id" optional="show"/>
                    <field name="ss_distributor_id" optional="show"/>
                </xpath>
            </field>
        </record>

        <!-- Action & Menu for Van Loading Locations -->
        <record id="action_van_loading_locations" model="ir.actions.act_window">
            <field name="name">Van Loading Locations</field>
            <field name="res_model">stock.location</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('ss_location_type', '=', 'van_loading')]</field>
            <field name="context">{'default_ss_location_type': 'van_loading', 'default_usage': 'customer'}</field>
        </record>

        <!-- Action & Menu for Distributor Locations -->
        <record id="action_distributor_locations" model="ir.actions.act_window">
            <field name="name">Distributor Locations</field>
            <field name="res_model">stock.location</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('ss_location_type', '=', 'distributor_location')]</field>
            <field name="context">{'default_ss_location_type': 'distributor_location', 'default_usage': 'customer'}</field>
        </record>

        <!-- Menu under Inventory / Configuration / Warehouse Management -->
        <menuitem id="menu_ss_distributor_locations" name="Distributor Locations" parent="stock.menu_warehouse_config" action="action_distributor_locations" sequence="11"/>
        <menuitem id="menu_ss_locations" name="Van Loading Locations" parent="stock.menu_warehouse_config" action="action_van_loading_locations" sequence="12"/>
    </data>
</odoo>
