<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Extend Barikoi Settings with Address Autocomplete Options -->
        <record id="res_config_settings_view_form_inherit_barikoi_autocomplete" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.barikoi.autocomplete</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="meta_barikoi_base.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//setting[@id='barikoi_maps_setting']//div[@id='barikoi_settings_content']" position="inside">
                    <div class="mt8">
                        <label for="barikoi_autocomplete_min_chars" string="Min Chars for Autocomplete" class="col-3 col-lg-3 o_light_label"/>
                        <field name="barikoi_autocomplete_min_chars" class="oe_inline"/>
                    </div>
                    <div class="mt8">
                        <label for="barikoi_autocomplete_limit" string="Suggestions Limit" class="col-3 col-lg-3 o_light_label"/>
                        <field name="barikoi_autocomplete_limit" class="oe_inline"/>
                    </div>
                </xpath>
            </field>
        </record>
    </data>
</odoo>